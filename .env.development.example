# Development API config. Copy to .env.development or .env.development.local.
# See src/config/api-env.ts for how these are used.

# =============================================================================
# Single-backend mode (auth, pipeline /api, crawler reports)
# One target at a time: local | stage | prod. Default: stage.
# =============================================================================
# VITE_API_MODE=stage
# VITE_API_MODE=local
# VITE_API_MODE=prod

# When VITE_API_MODE=local, proxy uses:
#   pipeline -> http://localhost:3001, auth -> http://localhost:3000
# When VITE_API_MODE=stage (default): stage-pipeline-api, stage auth.
# When VITE_API_MODE=prod: pipeline-api.klimatkollen.se, api.klimatkollen.se.

# Override specific proxy targets (optional; overrides mode defaults):
# VITE_PIPELINE_API_URL=http://localhost:3001
# VITE_AUTH_API_URL=http://localhost:3000
# VITE_SCREENSHOTS_API_URL=http://localhost:3000

# =============================================================================
# Comparison (Errors tab: always stage + prod)
# /stagekkapi and /kkapi proxies are fixed to stage and prod KK APIs.
# Override only if your stage/prod KK APIs live elsewhere.
# =============================================================================
# VITE_KK_API_URL=https://api.klimatkollen.se
# VITE_KK_STAGE_API_URL=https://stage-api.klimatkollen.se
