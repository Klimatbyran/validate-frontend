# Development API config. Copy to .env.development or .env.development.local.
# See src/config/api-env.ts and docs/API_AND_PROXY_SETUP.md.

# =============================================================================
# Joint override (sets both pipeline and Unearth/Garbo when not overridden)
# =============================================================================
# VITE_API_MODE=stage
# VITE_API_MODE=local
# VITE_API_MODE=prod

# =============================================================================
# Per-backend overrides
# =============================================================================
# VITE_PIPELINE_TARGET=local
# VITE_UNEARTH_TARGET=stage
# VITE_GARBO_ARCHIVE_TARGET=stage   # queue-archive only; defaults to Unearth target if unset
# VITE_GARBO_TARGET=stage           # legacy alias for VITE_UNEARTH_TARGET when UNEARTH_TARGET unset
#
# npm scripts (override .env.development): dev:local | dev:local-db | dev:local-db-pipeline | dev:local-full

# =============================================================================
# Pipeline (job status, upload): /pipeline-local, /pipeline-stage, or /pipeline
# =============================================================================
# VITE_PIPELINE_API_URL=http://localhost:3001
# VITE_PIPELINE_STAGE_URL=https://stage-pipeline-api.klimatkollen.se
# VITE_PIPELINE_PROD_URL=https://pipeline-api.klimatkollen.se

# =============================================================================
# Unearth HTTP API (auth, crawler, registry, overview): /unearth-local, /unearth-stage, /unearth
# =============================================================================
# VITE_UNEARTH_LOCAL_URL=http://localhost:3000
# VITE_UNEARTH_STAGE_URL=https://stage-api.unearthdata.ai
# VITE_UNEARTH_PROD_URL=https://api.unearthdata.ai

# Local Unearth (VITE_UNEARTH_TARGET=local): /unearth-local does not inject X-API-Key.
# Set on the Unearth API .env (not here):
#   ALLOW_ANONYMOUS_CLIENT_API=true

# =============================================================================
# Garbo API (queue-archive): /garbo-local, /garbo-stage, /garbo + /queue-archive
# =============================================================================
# VITE_GARBO_LOCAL_URL=http://localhost:3002
# VITE_GARBO_STAGE_URL=https://stage-api.klimatkollen.se
# VITE_GARBO_PROD_URL=https://api.klimatkollen.se

# =============================================================================
# Other
# =============================================================================
# VITE_SCREENSHOTS_API_URL=http://localhost:3000

# =============================================================================
# API keys (proxy injection; vite dev + nginx in staging/production)
# k8s Secret "env" — see k8s/base/deployment.yaml and docs/API_AND_PROXY_SETUP.md
#
# Three names because proxy paths hit different hosts (stage vs prod), not because
# the secret values must differ. You may use the same garb_<lookup>.<secret> in all
# three if that key is seeded in both stage and prod DBs.
#
# GARBO_ALL_ACCESS_API_KEY       — /unearth-api/ (primary target for this deployment)
# GARBO_STAGE_ALL_ACCESS_API_KEY — /unearth-stage-api/, /garbo-stage-api/ (dev: /unearth-stage, /garbo-stage)
# GARBO_PROD_ALL_ACCESS_API_KEY  — /unearth-prod-api/ (dev: /unearth) — Errors tab + prod cross-env
# =============================================================================
# GARBO_ALL_ACCESS_API_KEY=garb_yourlookup.yoursecret
# GARBO_STAGE_ALL_ACCESS_API_KEY=garb_yourlookup.yoursecret
# GARBO_PROD_ALL_ACCESS_API_KEY=garb_yourlookup.yoursecret
